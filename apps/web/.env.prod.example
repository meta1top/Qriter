# qriter web 生产部署环境变量样例（docker-compose interpolation 用）。
# 1. cp .env.prod.example .env.prod
# 2. 改 <change-me> 占位
# 3. docker compose --env-file .env.prod up -d --build
#
# .env.prod 已 gitignore（仓库根 .gitignore 覆盖 .env.prod）。

# ---- Nest server 内网地址（web 服务端 fetch + proxy.ts 转发用）----
# 指向 server 实际可达地址（同机不同容器 / 内网 host / 服务发现名）。
NEST_INTERNAL_URL=http://<change-me-server-host>:3000

# ---- host 暴露端口（默认 3001）----
WEB_PORT=3001

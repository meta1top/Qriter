# qriter server 生产部署环境变量样例（docker-compose interpolation 用）。
# 1. cp .env.prod.example .env.prod
# 2. 改 <change-me> 占位
# 3. docker compose --env-file .env.prod up -d --build
#
# .env.prod 已 gitignore（仓库根 .gitignore 覆盖 .env.prod）。
#
# 注意：server 的「业务配置」（database / jwt / redis / llm / port）不在这里，
# 而在 Nacos 的 dataId（见 apps/server/DEPLOY.md）。这里只放：
#   - server 连 Nacos 的引导信息（NACOS_*）
#   - host 暴露端口（SERVER_PORT，须与 Nacos 配置里的 port 一致）
# Postgres / Redis 由外部托管，server 经 Nacos 配置的 database.host / redis.host 连接。

# ---- server 连 Nacos（唯一需要的 server 环境变量）----
NACOS_SERVER_ADDR=<change-me-host:8848>
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=qriter-server.yaml
NACOS_USERNAME=<change-me>
NACOS_PASSWORD=<change-me>

# ---- host 暴露端口（须与 Nacos 配置 port 一致，默认 3000）----
SERVER_PORT=3000

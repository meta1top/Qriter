# qriter server 本地开发环境变量样例。
# 复制为 .env.development 后再使用（已 gitignore）。
#
# 启动 Postgres：pnpm dev:db:up

PORT=3000
DATABASE_URL=postgresql://qriter:qriter@localhost:5433/qriter
JWT_SECRET=qriter-dev-secret-change-in-prod-min-16
JWT_EXPIRES=7d
NODE_ENV=development

# 锁 / 缓存：留空（注释掉）走 memory 兜底；填了走 Redis。
# 本地起 redis：pnpm dev:db:up（端口 6380，避免与其它项目 6379 冲突）
# REDIS_URL=redis://localhost:6380

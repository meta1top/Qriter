# qriter server 生产环境变量样例。
# 1. cp .env.prod.example .env.prod
# 2. 修改下方 <change-me> 占位为真实 secret
# 3. docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# .env.prod 应 gitignore（仓库根 .gitignore 已覆盖 .env.*）

# ---- 数据库 ----
POSTGRES_USER=qriter
POSTGRES_PASSWORD=<change-me-strong-password>
POSTGRES_DB=qriter

# 容器内 server 使用的连接串（compose 已按此模板组装，单独部署时填这里）
DATABASE_URL=postgresql://qriter:<change-me-strong-password>@postgres:5432/qriter

# ---- Redis（可选；不填走 memory 兜底）----
REDIS_URL=redis://redis:6379

# ---- JWT ----
# 用 `openssl rand -base64 48` 生成 32 字节以上
JWT_SECRET=<change-me-base64-32-bytes>
JWT_EXPIRES=7d

# ---- 暴露端口 ----
SERVER_PORT=3000

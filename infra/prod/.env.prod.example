# qriter 生产部署环境变量样例（docker-compose interpolation 用）。
# 1. cp .env.prod.example .env.prod
# 2. 修改 <change-me> 占位
# 3. docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# .env.prod 应 gitignore（仓库根 .gitignore 已覆盖 .env.*）
#
# 注意：server 的「业务配置」（database / jwt / redis / llm / port / node_env）不在这里，
# 而在 Nacos 的 dataId（见 infra/prod/README.md）。这里只放：
#   - server 连 Nacos 的引导信息（NACOS_*）
#   - postgres 容器自身初始化（POSTGRES_*，须与 Nacos 配置里的 database.* 一致）
#   - host 暴露端口（SERVER_PORT，须与 Nacos 配置里的 port 一致）

# ---- server 连 Nacos（唯一需要的 server 环境变量）----
NACOS_SERVER_ADDR=<change-me-host:8848>
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=qriter-server.yaml
NACOS_USERNAME=<change-me>
NACOS_PASSWORD=<change-me>

# ---- postgres 容器初始化（须与 Nacos 配置 database.username/password/database 一致）----
POSTGRES_USER=qriter
POSTGRES_PASSWORD=<change-me-strong-password>
POSTGRES_DB=qriter

# ---- host 暴露端口（须与 Nacos 配置 port 一致，默认 3000）----
SERVER_PORT=3000
